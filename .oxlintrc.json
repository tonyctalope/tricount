{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "nextjs", "jsx-a11y"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-unused-vars": "warn",
    "typescript/no-unused-vars": "warn",
    "react/no-unescaped-entities": "off",
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": [
    "node_modules",
    ".next",
    "out",
    "build",
    "coverage",
    "next-env.d.ts",
    "prisma/migrations"
  ]
}
